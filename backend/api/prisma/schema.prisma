generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum SubscriptionPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum OnboardingStep {
  PROFILE
  DOCUMENTS
  PAYMENT
  COMPLETE
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  BOOKED
  EXPIRED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum InsuranceClaimStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  APPOINTMENT_STATUS_UPDATED
  INTAKE_FORM_SUBMITTED
  INTAKE_FORM_UPDATED
  PRESCRIPTION_CREATED
  PRESCRIPTION_UPDATED
  CONSULTATION_NOTE_SAVED
  REVIEW_SUBMITTED
  PROFILE_UPDATED
  SLOT_CREATED
  VIDEO_SESSION_STARTED
  INSURANCE_CARD_ADDED
  INSURANCE_CLAIM_SUBMITTED
  ADMIN_ACTION
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  subscription TenantSubscription?

  migrations PatientMigration[]
  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  role         UserRole  @default(PATIENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?
  auditLogs      AuditLog[]
  sentMessages   Message[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model DoctorProfile {
  id                 String         @id @default(uuid())
  userId             String         @unique
  specialty          String?
  bio                String?
  licenseNumber      String?
  licenseDocument    String?
  yearsOfExperience  Int?
  consultationFee    Decimal?       @db.Decimal(10, 2)
  isVerified         Boolean        @default(false)
  onboardingStep     OnboardingStep @default(PROFILE)
  onboardingComplete Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user                  User                   @relation(fields: [userId], references: [id])
  availabilitySlots     AvailabilitySlot[]
  reviews               Review[]
  prescriptions         Prescription[]
  consultationNotes     ConsultationNote[]
  waitlistEntries       Waitlist[]
  availabilityTemplates AvailabilityTemplate[]
  payouts               DoctorPayout[]
  commissions           PlatformCommission[]   @relation("DoctorCommissions")
  conversations         Conversation[]
  referralsGiven        Referral[]             @relation("ReferringDoctor")
  referralsReceived     Referral[]             @relation("SpecialistReferrals")

  migrations PatientMigration[]
  @@map("doctor_profiles")
}

model PatientProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  dateOfBirth DateTime?
  gender      Gender?
  phone       String?
  address     String?
  bloodGroup  String?
  allergies   String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user              User                 @relation(fields: [userId], references: [id])
  appointments      Appointment[]
  reviews           Review[]
  prescriptions     Prescription[]
  consultationNotes ConsultationNote[]
  intakeForms       IntakeForm[]
  waitlistEntries   Waitlist[]
  commissions       PlatformCommission[] @relation("PatientCommissions")
  conversations     Conversation[]
  insuranceCards    InsuranceCard[]
  insuranceClaims   InsuranceClaim[]
  referrals         Referral[]

  @@map("patient_profiles")
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  tenantId           String             @unique
  plan               SubscriptionPlan   @default(BASIC)
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant   Tenant                @relation(fields: [tenantId], references: [id])
  payments SubscriptionPayment[]

  @@map("tenant_subscriptions")
}

model SubscriptionPayment {
  id             String           @id @default(uuid())
  subscriptionId String
  amount         Decimal          @db.Decimal(10, 2)
  currency       String           @default("KES")
  status         PaymentStatus    @default(PENDING)
  mpesaRef       String?
  mpesaReceiptNo String?
  phoneNumber    String?
  plan           SubscriptionPlan
  paidAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_payments")
}

model AvailabilitySlot {
  id          String   @id @default(uuid())
  doctorId    String
  startTime   DateTime
  endTime     DateTime
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  appointment Appointment?

  @@index([doctorId])
  @@index([startTime])
  @@map("availability_slots")
}

model Appointment {
  id            String            @id @default(uuid())
  patientId     String
  slotId        String            @unique
  status        AppointmentStatus @default(PENDING)
  reason        String?
  notes         String?
  cancelledAt   DateTime?
  cancelReason  String?
  videoRoomName String?
  videoRoomUrl  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  patient          PatientProfile      @relation(fields: [patientId], references: [id])
  availabilitySlot AvailabilitySlot    @relation(fields: [slotId], references: [id])
  review           Review?
  prescription     Prescription?
  consultationNote ConsultationNote?
  intakeForm       IntakeForm?
  commission       PlatformCommission? @relation("AppointmentCommission")
  insuranceClaim   InsuranceClaim?     @relation("AppointmentInsuranceClaim")
  referral         Referral?

  @@index([patientId])
  @@index([slotId])
  @@map("appointments")
}

model IntakeForm {
  id              String   @id @default(uuid())
  appointmentId   String   @unique
  patientId       String
  symptoms        String[]
  symptomNotes    String?
  symptomDuration String?
  allergies       String[]
  allergyNotes    String?
  medications     Json     @default("[]")
  bloodPressure   String?
  weight          String?
  additionalNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment Appointment    @relation(fields: [appointmentId], references: [id])
  patient     PatientProfile @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("intake_forms")
}

model Review {
  id               String   @id @default(uuid())
  doctorProfileId  String
  patientProfileId String
  appointmentId    String   @unique
  rating           Int
  comment          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  doctorProfile  DoctorProfile  @relation(fields: [doctorProfileId], references: [id])
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id])
  appointment    Appointment    @relation(fields: [appointmentId], references: [id])

  @@index([doctorProfileId])
  @@map("reviews")
}

model Prescription {
  id               String    @id @default(uuid())
  appointmentId    String    @unique
  doctorProfileId  String
  patientProfileId String
  medications      Json
  diagnosis        String?
  notes            String?
  validUntil       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  appointment    Appointment    @relation(fields: [appointmentId], references: [id])
  doctorProfile  DoctorProfile  @relation(fields: [doctorProfileId], references: [id])
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id])

  @@index([doctorProfileId])
  @@index([patientProfileId])
  @@map("prescriptions")
}

model ConsultationNote {
  id               String   @id @default(uuid())
  appointmentId    String   @unique
  doctorProfileId  String
  patientProfileId String
  subjective       String?
  objective        String?
  assessment       String?
  plan             String?
  privateNotes     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointment    Appointment    @relation(fields: [appointmentId], references: [id])
  doctorProfile  DoctorProfile  @relation(fields: [doctorProfileId], references: [id])
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id])

  @@index([doctorProfileId])
  @@index([patientProfileId])
  @@map("consultation_notes")
}

model AvailabilityTemplate {
  id        String   @id @default(uuid())
  doctorId  String
  name      String
  isActive  Boolean  @default(true)
  timezone  String   @default("Africa/Nairobi")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor DoctorProfile              @relation(fields: [doctorId], references: [id])
  slots  AvailabilityTemplateSlot[]

  @@index([doctorId])
  @@map("availability_templates")
}

model AvailabilityTemplateSlot {
  id           String   @id @default(uuid())
  templateId   String
  dayOfWeek    Int
  startHour    Int
  startMinute  Int      @default(0)
  endHour      Int
  endMinute    Int      @default(0)
  slotMinutes  Int      @default(60)
  breakMinutes Int      @default(0)
  createdAt    DateTime @default(now())

  template AvailabilityTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("availability_template_slots")
}

model Waitlist {
  id              String         @id @default(uuid())
  patientId       String
  doctorProfileId String
  status          WaitlistStatus @default(WAITING)
  notifiedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  patient       PatientProfile @relation(fields: [patientId], references: [id])
  doctorProfile DoctorProfile  @relation(fields: [doctorProfileId], references: [id])

  @@unique([patientId, doctorProfileId])
  @@index([doctorProfileId])
  @@map("waitlist")
}

model InsuranceCard {
  id              String    @id @default(uuid())
  patientId       String
  provider        String
  memberNumber    String
  groupNumber     String?
  holderName      String
  validFrom       DateTime?
  validUntil      DateTime?
  cardImageBase64 String?   @db.Text
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient PatientProfile  @relation(fields: [patientId], references: [id])
  claims  InsuranceClaim[]

  @@index([patientId])
  @@map("insurance_cards")
}

model InsuranceClaim {
  id              String               @id @default(uuid())
  claimCode       String               @unique
  appointmentId   String               @unique
  patientId       String
  insuranceCardId String
  status          InsuranceClaimStatus @default(DRAFT)
  diagnosisCode   String?
  claimAmount     Decimal?             @db.Decimal(10, 2)
  approvedAmount  Decimal?             @db.Decimal(10, 2)
  notes           String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  appointment   Appointment    @relation("AppointmentInsuranceClaim", fields: [appointmentId], references: [id])
  patient       PatientProfile @relation(fields: [patientId], references: [id])
  insuranceCard InsuranceCard  @relation(fields: [insuranceCardId], references: [id])

  @@index([patientId])
  @@index([status])
  @@map("insurance_claims")
}

model PlatformCommission {
  id               String   @id @default(uuid())
  appointmentId    String   @unique
  doctorProfileId  String
  patientProfileId String
  consultationFee  Decimal  @db.Decimal(10, 2)
  commissionRate   Decimal  @db.Decimal(5, 2)
  commissionAmount Decimal  @db.Decimal(10, 2)
  doctorEarning    Decimal  @db.Decimal(10, 2)
  currency         String   @default("KES")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointment    Appointment    @relation("AppointmentCommission", fields: [appointmentId], references: [id])
  doctorProfile  DoctorProfile  @relation("DoctorCommissions", fields: [doctorProfileId], references: [id])
  patientProfile PatientProfile @relation("PatientCommissions", fields: [patientProfileId], references: [id])

  @@index([doctorProfileId])
  @@index([createdAt])
  @@map("platform_commissions")
}

model DoctorPayout {
  id              String       @id @default(uuid())
  doctorProfileId String
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("KES")
  status          PayoutStatus @default(PENDING)
  periodStart     DateTime
  periodEnd       DateTime
  mpesaRef        String?
  mpesaReceiptNo  String?
  phoneNumber     String?
  notes           String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id])

  @@index([doctorProfileId])
  @@index([status])
  @@map("doctor_payouts")
}

model Conversation {
  id               String   @id @default(uuid())
  doctorProfileId  String
  patientProfileId String
  lastMessageAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  doctorProfile  DoctorProfile  @relation(fields: [doctorProfileId], references: [id])
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id])
  messages       Message[]

  @@unique([doctorProfileId, patientProfileId])
  @@index([doctorProfileId])
  @@index([patientProfileId])
  @@map("conversations")
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  action    AuditAction
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  success   Boolean     @default(true)
  error     String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}


enum ReferralStatus {
  REQUESTED
  PENDING
  ACCEPTED
  BOOKED
  COMPLETED
  CANCELLED
  REJECTED
}

enum ReferralUrgency {
  ROUTINE
  URGENT
  EMERGENCY
}

model Referral {
  id                 String          @id @default(cuid())
  referralCode       String          @unique
  status             ReferralStatus  @default(PENDING)
  urgency            ReferralUrgency @default(ROUTINE)

  referringDoctorId  String
  referringDoctor    DoctorProfile   @relation("ReferringDoctor", fields: [referringDoctorId], references: [id])

  patientId          String
  patient            PatientProfile  @relation(fields: [patientId], references: [id])

  specialistId       String?
  specialist         DoctorProfile?  @relation("SpecialistReferrals", fields: [specialistId], references: [id])

  speciality         String
  reason             String
  notes              String?

  requestedByPatient Boolean         @default(false)
  approvedAt         DateTime?

  appointmentId      String?         @unique
  appointment        Appointment?    @relation(fields: [appointmentId], references: [id])

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([patientId])
  @@index([referringDoctorId])
  @@map("referrals")
}

model PatientMigration {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  doctorId        String
  doctor          DoctorProfile @relation(fields: [doctorId], references: [id])
  fileName        String
  status          MigrationStatus @default(PENDING)
  totalRows       Int      @default(0)
  processedRows   Int      @default(0)
  failedRows      Int      @default(0)
  errorLog        String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patients        MigrationPatient[]
  @@map("patient_migrations")
}

model MigrationPatient {
  id              String   @id @default(cuid())
  migrationId     String
  migration       PatientMigration @relation(fields: [migrationId], references: [id])
  fullName        String
  email           String
  phone           String?
  medicalHistory  String?
  diagnoses       String?
  status          MigrationPatientStatus @default(PENDING)
  userId          String?
  errorMessage    String?
  inviteToken     String?  @unique
  inviteExpiry    DateTime?
  createdAt       DateTime @default(now())
  @@map("migration_patients")
}

enum MigrationStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

enum MigrationPatientStatus {
  PENDING
  CREATED
  INVITED
  ACTIVATED
  FAILED
}
