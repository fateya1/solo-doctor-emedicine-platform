generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum SubscriptionPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum OnboardingStep {
  PROFILE
  DOCUMENTS
  PAYMENT
  COMPLETE
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  BOOKED
  EXPIRED
}

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  APPOINTMENT_BOOKED
  APPOINTMENT_CANCELLED
  APPOINTMENT_STATUS_UPDATED
  INTAKE_FORM_SUBMITTED
  INTAKE_FORM_UPDATED
  PRESCRIPTION_CREATED
  PRESCRIPTION_UPDATED
  CONSULTATION_NOTE_SAVED
  REVIEW_SUBMITTED
  PROFILE_UPDATED
  SLOT_CREATED
  VIDEO_SESSION_STARTED
  ADMIN_ACTION
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  subscription TenantSubscription?

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  role         UserRole  @default(PATIENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?
  auditLogs      AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model DoctorProfile {
  id                 String         @id @default(uuid())
  userId             String         @unique
  specialty          String?
  bio                String?
  licenseNumber      String?
  licenseDocument    String?
  yearsOfExperience  Int?
  consultationFee    Decimal?       @db.Decimal(10, 2)
  isVerified         Boolean        @default(false)
  onboardingStep     OnboardingStep @default(PROFILE)
  onboardingComplete Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  availabilitySlots AvailabilitySlot[]
  reviews           Review[]
  prescriptions     Prescription[]
  consultationNotes ConsultationNote[]
  waitlistEntries   Waitlist[]
  availabilityTemplates AvailabilityTemplate[]

  @@map("doctor_profiles")
}

model PatientProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  dateOfBirth DateTime?
  gender      Gender?
  phone       String?
  address     String?
  bloodGroup  String?
  allergies   String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  appointments      Appointment[]
  reviews           Review[]
  prescriptions     Prescription[]
  consultationNotes ConsultationNote[]
  intakeForms       IntakeForm[]
  waitlistEntries   Waitlist[]

  @@map("patient_profiles")
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  tenantId           String             @unique
  plan               SubscriptionPlan   @default(BASIC)
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant   Tenant                @relation(fields: [tenantId], references: [id])
  payments SubscriptionPayment[]

  @@map("tenant_subscriptions")
}

model SubscriptionPayment {
  id             String           @id @default(uuid())
  subscriptionId String
  amount         Decimal          @db.Decimal(10, 2)
  currency       String           @default("KES")
  status         PaymentStatus    @default(PENDING)
  mpesaRef       String?
  mpesaReceiptNo String?
  phoneNumber    String?
  plan           SubscriptionPlan
  paidAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_payments")
}

model AvailabilitySlot {
  id          String   @id @default(uuid())
  doctorId    String
  startTime   DateTime
  endTime     DateTime
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctor      DoctorProfile @relation(fields: [doctorId], references: [id])
  appointment Appointment?

  @@index([doctorId])
  @@index([startTime])
  @@map("availability_slots")
}

model Appointment {
  id            String            @id @default(uuid())
  patientId     String
  slotId        String            @unique
  status        AppointmentStatus @default(PENDING)
  reason        String?
  notes         String?
  cancelledAt   DateTime?
  cancelReason  String?
  videoRoomName String?
  videoRoomUrl  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  patient          PatientProfile    @relation(fields: [patientId], references: [id])
  availabilitySlot AvailabilitySlot  @relation(fields: [slotId], references: [id])
  review           Review?
  prescription     Prescription?
  consultationNote ConsultationNote?
  intakeForm       IntakeForm?

  @@index([patientId])
  @@index([slotId])
  @@map("appointments")
}

model IntakeForm {
  id              String   @id @default(uuid())
  appointmentId   String   @unique
  patientId       String
  symptoms        String[]
  symptomNotes    String?
  symptomDuration String?
  allergies       String[]
  allergyNotes    String?
  medications     Json     @default("[]")
  bloodPressure   String?
  weight          String?
  additionalNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointment Appointment    @relation(fields: [appointmentId], references: [id])
  patient     PatientProfile @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("intake_forms")
}

model Review {
  id               String   @id @default(uuid())
  doctorProfileId  String
  patientProfileId String
  appointmentId    String   @unique
  rating           Int
  comment          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  doctorProfile  DoctorProfile  @relation(fields: [doctorProfileId], references: [id])
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id])
  appointment    Appointment    @relation(fields: [appointmentId], references: [id])

  @@index([doctorProfileId])
  @@map("reviews")
}

model Prescription {
  id               String    @id @default(uuid())
  appointmentId    String    @unique
  doctorProfileId  String
  patientProfileId String
  medications      Json
  diagnosis        String?
  notes            String?
  validUntil       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  appointment    Appointment    @relation(fields: [appointmentId], references: [id])
  doctorProfile  DoctorProfile  @relation(fields: [doctorProfileId], references: [id])
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id])

  @@index([doctorProfileId])
  @@index([patientProfileId])
  @@map("prescriptions")
}

model ConsultationNote {
  id               String   @id @default(uuid())
  appointmentId    String   @unique
  doctorProfileId  String
  patientProfileId String
  subjective       String?
  objective        String?
  assessment       String?
  plan             String?
  privateNotes     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointment    Appointment    @relation(fields: [appointmentId], references: [id])
  doctorProfile  DoctorProfile  @relation(fields: [doctorProfileId], references: [id])
  patientProfile PatientProfile @relation(fields: [patientProfileId], references: [id])

  @@index([doctorProfileId])
  @@index([patientProfileId])
  @@map("consultation_notes")
}

model AvailabilityTemplate {
  id        String   @id @default(uuid())
  doctorId  String
  name      String
  isActive  Boolean  @default(true)
  timezone  String   @default("Africa/Nairobi")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor DoctorProfile              @relation(fields: [doctorId], references: [id])
  slots  AvailabilityTemplateSlot[]

  @@index([doctorId])
  @@map("availability_templates")
}

model AvailabilityTemplateSlot {
  id           String   @id @default(uuid())
  templateId   String
  dayOfWeek    Int      // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat
  startHour    Int
  startMinute  Int      @default(0)
  endHour      Int
  endMinute    Int      @default(0)
  slotMinutes  Int      @default(60)
  breakMinutes Int      @default(0)
  createdAt    DateTime @default(now())

  template AvailabilityTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("availability_template_slots")
}

model Waitlist {
  id              String         @id @default(uuid())
  patientId       String
  doctorProfileId String
  status          WaitlistStatus @default(WAITING)
  notifiedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  patient       PatientProfile @relation(fields: [patientId], references: [id])
  doctorProfile DoctorProfile  @relation(fields: [doctorProfileId], references: [id])

  @@unique([patientId, doctorProfileId])
  @@index([doctorProfileId])
  @@map("waitlist")
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  action    AuditAction
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  success   Boolean     @default(true)
  error     String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
